{
    "name": "ziwot/merkle-airdrop",
    "description": "Demo Merkle Airdrop on Tezos",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "cakephp/authentication": "^3.0",
        "cakephp/cakephp": "5.3.*",
        "cakephp/migrations": "^5.0",
        "cakephp/plugin-installer": "^2.0",
        "friendsofcake/bootstrap-ui": "^5.1",
        "mobiledetect/mobiledetectlib": "^4.8.03",
        "ziwot/cake-tezos": "@dev",
        "zunnu/cake-htmx": "^1.0"
    },
    "require-dev": {
        "cakedc/cakephp-phpstan": "^4.1",
        "cakephp/bake": "^3.6",
        "cakephp/debug_kit": "^5.2",
        "cakephp/repl": "^2.0",
        "dereuromark/cakephp-ide-helper": "^2.16",
        "josegonzalez/dotenv": "^4.0",
        "php-collective/code-sniffer": "^0.5.4",
        "phpstan/extension-installer": "^1.4",
        "phpunit/phpunit": "^11.5.3 || ^12.1.3 || ^13.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Test\\": "tests/",
            "Cake\\Test\\": "vendor/cakephp/cakephp/tests/"
        }
    },
    "scripts": {
        "check": ["@test", "@cs-check"],
        "cs-check": "phpcs --colors --parallel=16 -p",
        "cs-fix": "phpcbf --colors --parallel=16 -p",
        "stan": "phpstan analyse --memory-limit 256M",
        "test": "phpunit --colors=always"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "cakephp/plugin-installer": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "php-http/discovery": true,
            "phpstan/extension-installer": true
        }
    },
    "prefer-stable": true,
    "repositories": {
        "dev-package": {
            "type": "path",
            "url": "/home/steven/code/ziwot/cake-tezos",
            "options": {
                "symlink": true
            }
        }
    }
}
